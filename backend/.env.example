# ── Backend (Go API) — copy to backend/.env (gitignored) ──────
# 12-Factor: alle Konfiguration über Env-Variablen (CLAUDE.md §7).

# Runtime
ENV=development                # development | production
PORT=8080
LOG_LEVEL=debug                # debug | info | warn | error

# Datenbank (PostgreSQL 17) — lokal via docker-compose
DATABASE_URL=postgres://prekaj:prekaj@localhost:5432/prekaj?sslmode=disable

# Auth (CLAUDE.md §8) — NIEMALS echten Wert committen
JWT_SECRET=change-me-in-local-only-min-32-chars-random
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h         # 30 Tage
BCRYPT_COST=12

# CORS — strikte Allowlist (Web-Origin); kommagetrennt
CORS_ORIGINS=http://localhost:5173

# Seed-Admin (Inhaber) — nur für lokale Erstinitialisierung
SEED_ADMIN_EMAIL=admin@fliesenprekaj.local
SEED_ADMIN_PASSWORD=change-me-locally
SEED_ADMIN_NAME=Inhaber

# Zeitzone (CLAUDE.md §13: Europe/Vienna, UTC speichern)
APP_TIMEZONE=Europe/Vienna
