# ── Mobile (Expo / RN) — copy to mobile/.env (gitignored) ─────
# EXPO_PUBLIC_-Variablen sind im App-Bundle sichtbar (keine Secrets!).
# Refresh-Token wird zur Laufzeit in expo-secure-store gehalten (CLAUDE.md §8/§10).

# Simulator/Emulator erreicht den Host unterschiedlich:
#   iOS-Simulator   -> localhost
#   Android-Emulator-> 10.0.2.2
#   echtes Gerät    -> LAN-IP des Macs
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
EXPO_PUBLIC_APP_NAME=Prekaj-Zeiterfassung
EXPO_PUBLIC_ENV=development

# EAS (CLAUDE.md §10/§12) — in Phase 9/12 gefüllt
# EAS_PROJECT_ID=
